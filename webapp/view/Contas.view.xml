<mvc:View
    controllerName="portalrbl.app.ui5.controller.Contas"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <Page
        title="{i18n>finPageTitle}"
        showNavButton="false"
    >
        <content>
            <VBox class="sapUiSmallMargin">
                <HBox
                    alignItems="Center"
                    justifyContent="SpaceBetween"
                    width="100%"
                    class="sapUiTinyMarginBottom"
                >
                    <HBox alignItems="Center">
                        <Avatar
                            src="{usuarioLogado>/photoURL}"
                            displayShape="Circle"
                            displaySize="XS"
                            class="sapUiTinyMarginEnd"
                            fallbackIcon="sap-icon://person-placeholder"
                        />
                        <Text
                            text="Olá, {usuarioLogado>/displayName}"
                            class="sapUiSelectableText"
                        />
                    </HBox>
                    <ToggleButton
                        id="idFlagPessoal"
                        icon="sap-icon://role"
                        pressed="false"
                        tooltip="Grupo {= ${usuarioLogado>/grupoAtivo} }"
                        press="onToggleTipoDespesa"
                    />
                </HBox>
                <MessageStrip
                    text="Nubank dia 04, Picpay dia 05"
                    type="Information"
                    showIcon="true"
                    showCloseButton="true"
                    class="sapUiMediumMarginBottom"
                    
                />
                <HBox
                    visible="{= ${usuarioLogado>/grupoAtivo} === '0' }"
                    wrap="Wrap"
                    justifyContent="Start"
                    class="sapUiTinyMarginBottom"
                >
                    <GenericTile
                        id="idTotalR"
                        frameType="OneByHalf"
                        header="Ramon"
                        width="9rem"
                        class="sapUiTinyMarginEnd sapUiTinyMarginBottom compactTile"
                    >
                        <TileContent>
                            <ObjectNumber
                                number="0,00"
                                unit="BRL"
                                state="Success"
                                class="customNumberTile"
                            />
                        </TileContent>
                    </GenericTile>
                    <GenericTile
                        id="idTotalF"
                        frameType="OneByHalf"
                        header="Fabi"
                        width="9rem"
                        class="sapUiTinyMarginEnd sapUiTinyMarginBottom compactTile"
                    >
                        <TileContent>
                            <ObjectNumber
                                number="0,00"
                                unit="BRL"
                                state="Success"
                                class="customNumberTile"
                            />
                        </TileContent>
                    </GenericTile>
                </HBox>

                <!-- Formulário de Lançamento -->
                <form:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    title="{i18n>finFormTitle}"
                >
                    <form:content>
                        <Label text="{i18n>finLabelData}" />
                        <DatePicker
                            id="idDataLancamento"
                            displayFormat="short"
                            valueFormat="yyyy-MM-dd"
                            placeholder="Selecione a data"
                            change="onDatePickerChange"
                        />

                        <Label text="{i18n>finLabelValor}" />
                        <Input
                            id="idValorDespesa"
                            type="Number"
                            placeholder="0,00"
                            description="BRL"
                        />

                        <Label text="{i18n>finLabelDescricao}" />
                        <Input
                            id="idDescricaoDespesa"
                            placeholder="Ex: Supermercado"
                        />
                        <Label text="" />
                        <Button
                            text="{i18n>finBtnInsert}"
                            type="Emphasized"
                            press="onAddExpense"
                            width="150px"
                        />
                    </form:content>
                </form:SimpleForm>
                <!-- Tabela de Despesas -->
                <Table
                    id="idTableDespesas"
                    items="{localModel>/expenses}"
                    class="sapUiMediumMarginTop"
                    noDataText="{i18n>finNoData}"
                >
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="{i18n>finTableTitle}" />
                            <ToolbarSpacer />
                            <!-- Exibição do Total -->
                            <ObjectStatus
                                id="idTotalMes"
                                title="Total do Mês"
                                text="R$ 0,00"
                                state="Success"
                                class="sapUiSmallMarginEnd"
                            />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column>
                            <Text text="{i18n>finColData}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>finColDescricao}" />
                        </Column>
                        <Column hAlign="End">
                            <Text text="{i18n>finColValor}" />
                        </Column>
                        <Column
                            width="3rem"
                            hAlign="Center"
                        >
                            <Text text="" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text
                                    text="{ path: 'localModel>date', type: 'sap.ui.model.type.DateTime', formatOptions: { source: { pattern: 'yyyy-MM-ddTHH:mm:ss.SSSX' }, pattern: 'dd/MM/yyyy', UTC: true } }"
                                />
                                <Text text="{localModel>description}" />
                                <ObjectNumber
                                    number="{path: 'localModel>value', type: 'sap.ui.model.type.Float', formatOptions: { minFractionDigits: 2 }}"
                                    unit="BRL"
                                    state="Error"
                                />
                                <Button
                                    icon="sap-icon://delete"
                                    type="Transparent"
                                    press="onDeleteExpense"
                                    tooltip="Excluir Lançamento"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
